[4.006, "o", "\r\n    Every edge carries provenance.\r\n    [tree-sitter:resolved] means the relationship is source-backed.\r\n"]
[0.000, "o", "    [llm:inferred] means the LLM proposed it — treat as a hint.\r\n    The agent always knows how much to trust the graph.\r\n"]
[4.008, "o", "\r\n    $ gm doctor\r\n\r\n"]
[0.026, "o", "  graph schema .................. 0.2.0\r\n  built by ...................... gm 0.1.0\r\n  extraction modes ............. ast\r\n  detected languages ........... rust\r\n  tree-sitter languages ........ 9 (rust, python, go, javascript, typescript, c, cpp, java, csharp)\r\n  graph quality ................ 54% extracted, 46% inferred, 0% ambiguous\r\n"]
[3.006, "o", "\r\n"]
[0.000, "o", "    ┌─────────────────────────────────────────────────────────────┐\r\n"]
[0.000, "o", "    │  Without Graphenium                                        │\r\n    │  grep -> read file -> trace imports -> read more -> repeat │\r\n"]
[0.000, "o", "    │                                                             │\r\n"]
[0.000, "o", "    │  With Graphenium                                            │\r\n"]
[0.000, "o", "    │  query_graph -> get_neighbors -> shortest_path              │\r\n"]
[0.001, "o", "    │  2 graph calls before opening a single source file          │\r\n"]
[0.000, "o", "    └─────────────────────────────────────────────────────────────┘\r\n"]
[4.010, "o", "\r\n    github.com/lambda-alpha-labs/Graphenium\r\n"]
